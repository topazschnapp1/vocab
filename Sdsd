let knownWords = {};
try { knownWords = JSON.parse(localStorage.getItem('knownWords2') || '{}'); } catch(e) {}
function saveKnown() { try { localStorage.setItem('knownWords2', JSON.stringify(knownWords)); } catch(e) {} }

const list = document.getElementById('wordList');
words.forEach((w, i) => {
  const row = document.createElement('div');
  row.className = 'row' + (knownWords[w[0]] ? ' known' : '');
  row.id = 'row-' + i;
  row.innerHTML = `
    <div class="row-top">
      <span class="num">${i+1}</span>
      <span class="en">${w[0]}</span>
      <span class="he">${w[1]}</span>
      <span class="speaker">🔊</span>
      <button class="trash-btn">🗑</button>
    </div>
    <div class="sentence">${w[2]}</div>
  `;
  row.onclick = (e) => {
    if (e.target.classList.contains('he') || e.target.classList.contains('trash-btn')) return;
    if (!isReading) { currentIndex = i; startReading(i); }
  };
  row.querySelector('.he').onclick = (e) => { e.stopPropagation(); e.target.classList.toggle('revealed'); };
  row.querySelector('.trash-btn').onclick = (e) => { e.stopPropagation(); toggleKnown(i); };
  list.appendChild(row);
});

updateCounter();

function toggleKnown(i) {
  const key = words[i][0];
  const row = document.getElementById('row-' + i);
  if (knownWords[key]) { delete knownWords[key]; row.classList.remove('known'); }
  else { knownWords[key] = true; row.classList.add('known'); }
  saveKnown(); updateCounter();
}

function updateCounter() {
  const k = words.filter(w => knownWords[w[0]]).length;
  document.getElementById('counter').innerHTML = `ללימוד: <b>${words.length - k}</b> | יודעת: <b>${k}</b>`;
}

function toggleShowKnown() {
  const btn = document.getElementById('showKnownBtn');
  document.body.classList.toggle('show-known');
  const on = document.body.classList.contains('show-known');
  btn.className = on ? 'toggle-btn' : 'toggle-btn off';
  btn.textContent = on ? 'הסתר ידועות' : 'הצג ידועות';
}

function resetKnown() {
  if (!confirm('לאפס את כל המילים הידועות?')) return;
  knownWords = {}; saveKnown();
  document.querySelectorAll('.row.known').forEach(r => r.classList.remove('known'));
  updateCounter();
}

function toggleSentences() {
  showSentences = !showSentences;
  document.getElementById('toggleBtn').className = 'toggle-btn' + (showSentences ? '' : ' off');
  document.querySelectorAll('.sentence').forEach(s => s.style.display = showSentences ? '' : 'none');
}

function findNextActive(from) {
  for (let i = from; i < words.length; i++) {
    if (!knownWords[words[i][0]]) return i;
  }
  return -1;
}

function continueReading() { startReading(currentIndex); }
function restartReading() {
  const n = findNextActive(0);
  if (n === -1) { alert('סימנת את כל המילים!'); return; }
  startReading(n);
}

function startReading(from) {
  const n = findNextActive(from);
  if (n === -1) { alert('סימנת את כל המילים!'); return; }
  stopFlag = false; isReading = true; currentIndex = n;
  document.getElementById('btnPlay').style.display = 'none';
  document.getElementById('btnRestart').style.display = 'none';
  document.getElementById('btnStop').style.display = 'inline-block';
  readNext();
}

function stopReading() {
  stopFlag = true; isReading = false;
  if (currentAudio) { currentAudio.pause(); currentAudio = null; }
  document.querySelectorAll('.row.active').forEach(r => r.classList.remove('active'));
  document.getElementById('btnPlay').style.display = 'inline-block';
  document.getElementById('btnStop').style.display = 'none';
  document.getElementById('btnRestart').style.display = currentIndex > 0 ? 'inline-block' : 'none';
  document.getElementById('btnPlay').textContent = currentIndex > 0 ? '▶ המשך' : '▶ הקרא הכל';
  document.getElementById('statusText').textContent = currentIndex > 0 ? `עצרת: ${words[currentIndex]?.[0] || ''}` : 'לחץ על שורה או הקרא הכל';
  document.getElementById('progress').style.width = Math.round((currentIndex / words.length) * 100) + '%';
}

function readNext() {
  if (stopFlag) return;
  const n = findNextActive(currentIndex);
  if (n === -1) {
    document.getElementById('statusText').textContent = '✓ סיימנו!';
    stopReading(); return;
  }
  currentIndex = n;

  document.querySelectorAll('.row.active').forEach(r => r.classList.remove('active'));
  const row = document.getElementById('row-' + currentIndex);
  row.classList.add('active');
  row.scrollIntoView({ behavior: 'smooth', block: 'center' });
  document.getElementById('progress').style.width = Math.round((currentIndex / words.length) * 100) + '%';
  document.getElementById('statusText').textContent = words[currentIndex][0];

  const savedIndex = currentIndex;
  const en = words[currentIndex][0];
  const sentence = words[currentIndex][2];

  speakEL(en, () => {
    if (stopFlag) { currentIndex = savedIndex; return; }
    if (showSentences) {
      speakEL(sentence, () => {
        if (stopFlag) { currentIndex = savedIndex; return; }
        currentIndex++;
        setTimeout(readNext, 400);
      });
    } else {
      currentIndex++;
      setTimeout(readNext, 400);
    }
  });
}

document.addEventListener('visibilitychange', () => {
  if (!document.hidden && isReading && currentAudio) currentAudio.play();
});
</script>
</body>
</html>
