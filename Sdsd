async function speakEL(text, onEnd) {
  if (stopFlag) { onEnd(); return; }
  const voiceId = voiceMap[document.getElementById('voiceSelect').value] || voiceMap['Rachel'];
  const speed = parseFloat(document.getElementById('speedSelect').value);
  try {
    const res = await fetch('https://api.elevenlabs.io/v1/text-to-speech/' + voiceId, {
      method: 'POST',
      headers: { 'xi-api-key': API_KEY, 'Content-Type': 'application/json' },
      body: JSON.stringify({
        text,
        model_id: 'eleven_monolingual_v1',
        voice_settings: { stability: 0.5, similarity_boost: 0.75, speed }
      })
    });
    if (!res.ok) { onEnd(); return; }
    const url = URL.createObjectURL(await res.blob());
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    currentAudio = new Audio(url);
    currentAudio.onended = () => { URL.revokeObjectURL(url); onEnd(); };
    currentAudio.onerror = () => { URL.revokeObjectURL(url); onEnd(); };
    currentAudio.play();
  } catch(e) { onEnd(); }
}

